void move(const int dir, int speed) {
  int leftSpeed = 0;
  int rightSpeed = 0;
  if(dir == 1) {
    leftSpeed = speed;
    rightSpeed = speed;
  } else if(dir == 2) {
    leftSpeed = -speed;
    rightSpeed = -speed;
  } else if(dir == 3) {
    leftSpeed = -speed;
    rightSpeed = speed;
  } else if(dir == 4) {
    leftSpeed = speed;
    rightSpeed = -speed;
  }
  motor_9.run((9) == M1 ? -(leftSpeed) : (leftSpeed));
  motor_10.run((10) == M1 ? -(rightSpeed) : (rightSpeed));
}


void _delay(float seconds, move_param& param, coordinate& coord, bool CoordUpdate) {
  long endTime = millis() + seconds * 1000;
  while(millis() < endTime) _loop();
	//update coord
	if(CoordUpdate){
		coord.x += 2*PI*param.speed*param.engine_speed_coeff*seconds*std::cos(coord.phi)*(param.diameter/2);// s = v*t = 2pi n * t
		coord.y += 2*PI*param.speed*param.engine_speed_coeff*seconds*std::sin(coord.phi)*(param.diameter/2);
	}
}

// for v2.1
void rotate_bot(move_param &param, coordinate & coord, float phi){ // phi in grad
	coord.phi += phi;
	float theta = phi*(PI/180);
	float t = (param.wheelbase*theta)/(param.speed*param.engine_speed_coeff*2*PI*(param.diameter/2)); // t = wb*theta/n*2*pi*r
	if(phi>0){
		move(param.turnLeft, param.speed);
	}if(phi<0){
		move(param.turnRight, param.speed);
	}
	_delay(t, param, coord, false);

}

//for v2.2
void rotate_bot_undefined(move_param &param, std::string direction){ // phi in grad
	if(direction == "LEFT"){
		move(param.turnLeft, param.speed);
	}else if(direction == "RIGHT"){
		move(param.turnRight, param.speed);
	}else{
		return 0
	}

}

void addCoordRot(move_param &param, coordinate& coord, time &tc){
	float t = tc.time_end-tc.time_start;
	float phi_ = (t *  param.speed * param.engine_speed_coeff * param.diameter)/ param.wheelbase; //in rad
	coord.phi += phi_;
}

void addCoordTrans(move_param &param, coordinate& coord, time &tc, std::vector<float> &list){
	float t = tc.time_end-tc.time_start;
	float delta = 2*PI*param.diameter*param.speed*t//v = 2pirn - v = s/t --> s = v*t = 2pirn*t
	float delta_x = delta*std::cos(coord.phi);
	float delta_y = delta*std::sin(coord.phi);
	coord.x += delta_x; // 
	coord.y += delta_y;
	list.push_back((delta_x, delta_y))
}

double getLastTime(){
  return currentTime = millis() / 1000.0 - lastTime;
}



